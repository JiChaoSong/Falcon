PROJECT_NAME=Falcon
VERSION=1.0.0
ENVIRONMENT=prod
DEBUG=False
HOST=0.0.0.0
PORT=8008

GRPC_MASTER_HOST=0.0.0.0
GRPC_MASTER_PORT=50051
GRPC_WORKERS=falcon-worker:50061
WORKER_SHARED_TOKEN=change-me-worker-token
GRPC_WORKER_HEARTBEAT_TIMEOUT_SECONDS=15
GRPC_WORKER_HEALTH_CHECK_ENABLED=True
GRPC_WORKER_HEALTH_CHECK_INTERVAL_SECONDS=30
GRPC_WORKER_HISTORY_RETENTION_SECONDS=86400
GRPC_SCHEDULING_STRATEGY=least_loaded

DATABASE_URL=mysql+pymysql://falcon:falcon@mysql:3306/falcon
SECRET_KEY=change-me-secret-key
REFRESH_SECRET_KEY=change-me-refresh-secret-key
ALGORITHM=HS256
CORS_ORIGINS=["http://localhost:8080"]
