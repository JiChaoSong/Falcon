# 项目名称，用于日志、文档标题和系统展示
PROJECT_NAME='Falcon'

# 项目版本号，用于接口文档和节点上报
VERSION='1.0.0'

# 控制面 HTTP 服务绑定地址
HOST='127.0.0.1'

# 是否开启调试模式，开发环境可设为 True
DEBUG=True

# 控制面 HTTP 服务端口
PORT=8008

# 控制面 gRPC 服务绑定地址，供 worker 回调和控制命令使用
GRPC_MASTER_HOST='127.0.0.1'

# 控制面 gRPC 服务端口
GRPC_MASTER_PORT=50051

# 兼容保留字段，表示默认 worker 地址列表；当前调度以 workers 表为主
GRPC_WORKERS='127.0.0.1:50061'

# 控制面与 worker 通信使用的共享令牌，双方必须保持一致
WORKER_SHARED_TOKEN='change-me-worker-token'

# worker 心跳超时时间，单位秒；超过该时间会被标记为离线
GRPC_WORKER_HEARTBEAT_TIMEOUT_SECONDS=15

# 是否启用主动健康检查，默认开启
GRPC_WORKER_HEALTH_CHECK_ENABLED=True

# 主动健康检查间隔，单位秒
GRPC_WORKER_HEALTH_CHECK_INTERVAL_SECONDS=30

# 历史离线 worker 的保留时间，单位秒；超过后会自动清理
GRPC_WORKER_HISTORY_RETENTION_SECONDS=86400

# worker 调度策略，可选 least_loaded / weighted / round_robin
GRPC_SCHEDULING_STRATEGY='least_loaded'

# 数据库连接串，请按实际环境替换用户名、密码、主机和库名
DATABASE_URL='mysql+pymysql://****:******@localhost:3306/perflocust'

# 主密钥，用于访问令牌签名、加密和会话安全
SECRET_KEY='*********************'

# 刷新令牌密钥，必须与主密钥不同
REFRESH_SECRET_KEY='***************************'

# JWT 签名算法
ALGORITHM=HS256

# 跨域设置, 多个域名用逗号隔开
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
